@echo off
title تشغيل نظام الجدارة الائتمانية وسداد المديونيات
chcp 65001 >nul
color 0A
echo =====================================================================
echo       نظام الجدارة الائتمانية وسداد المديونيات - التشغيل المحلي
echo =====================================================================
echo.
echo [1/3] جاري التحقق من تثبيت بايثون (Python)...
python --version >nul 2>&1
if errorlevel 1 (
    color 0C
    echo [خطأ] بايثون (Python) غير مثبت على هذا الجهاز!
    echo.
    echo يرجى تحميل وتثبيت بايثون من الموقع الرسمي:
    echo https://www.python.org/downloads/
    echo.
    echo هام جداً: تأكد من تحديد خيار "Add Python to PATH" أثناء التثبيت.
    echo.
    pause
    exit /b
)

echo [2/3] جاري التحقق من المكتبات البرمجية المطلوبة وتثبيتها...
echo (قد يستغرق ذلك دقيقة في المرة الأولى فقط)...
pip install fastapi uvicorn openpyxl >nul 2>&1

echo [3/3] جاري بدء تشغيل الخادم الائتماني ومزامنة Excel...
echo.
echo ---------------------------------------------------------------------
echo  ملاحظة: يرجى إبقاء هذه النافذة السوداء مفتوحة أثناء عملك على النظام.
echo        عند الانتهاء، يمكنك ببساطة إغلاق هذه النافذة لإيقاف السيرفر.
echo ---------------------------------------------------------------------
echo.

:: فتح متصفح الإنترنت الافتراضي على موقع النظام بعد ثانيتين لضمان استجابة السيرفر
start /b cmd /c "timeout /t 2 /nobreak >nul && start http://127.0.0.1:8000"

:: تشغيل السيرفر
python server.py

pause
